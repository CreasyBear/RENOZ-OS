{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CRM lead to website customer overrides",
  "type": "object",
  "required": ["overrides"],
  "properties": {
    "overrides": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "crm_lead_id",
          "website_customer_id",
          "website_customer_name",
          "reason"
        ],
        "properties": {
          "crm_lead_id": { "type": "string", "format": "uuid" },
          "crm_label": { "type": "string" },
          "website_customer_id": { "type": "string", "format": "uuid" },
          "website_customer_name": { "type": "string" },
          "reason": { "type": "string" }
        }
      }
    }
  }
}
